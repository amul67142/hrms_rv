generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Announcement {
  id        String   @id @default(cuid()) 
  title     String
  content   String   
  type      String   @default("GENERAL") 
  priority  String   @default("NORMAL") 
  isActive  Boolean  @default(true)
  sentEmail Boolean  @default(false)
  createdBy String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model Attendance {
  id          String    @id @default(cuid()) 
  employeeId  String    
  date        DateTime
  status      String    
  inTime      String?   
  outTime     String?   
  hoursWorked Float?
  remarks     String?   
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@map("attendance")
}

model AttendanceRegularization {
  id             String    @id @default(cuid()) 
  employeeId     String    
  date           DateTime
  type           String    
  reason         String    
  status         String    @default("PENDING") 
  approvedBy     String?   
  approvedAt     DateTime?
  managerRemarks String?   
  deductions     Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("attendance_regularizations")
}

model AuditLog {
  id          String    @id @default(cuid()) 
  userId      String?   
  employeeId  String?   
  module      String    
  action      String    
  description String    
  oldValue    String?   
  newValue    String?   
  ipAddress   String?   
  userAgent   String?   
  createdAt   DateTime  @default(now())
  employee    Employee? @relation(fields: [employeeId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([employeeId])
  @@index([module])
  @@index([userId])
  @@map("audit_logs")
}

model CompanySetting {
  id                             String   @id @default(cuid()) 
  companyName                    String
  companyAddress                 String?  
  phone                          String?  
  email                          String?
  website                        String?
  logo                           String?  
  registrationNumber             String?  
  pan                            String?  
  tan                            String?  
  pfNumber                       String?  
  esiNumber                      String?  
  ptNumber                       String?  
  bankName                       String?
  bankAccountNumber              String?  
  bankAccountHolder              String?
  bankIfsc                       String?  
  logoUrl                        String?  
  workingDaysPerWeek             Int      @default(5)
  shiftStartTime                 String   @default("09:00") 
  shiftEndTime                   String   @default("18:00") 
  halfDayHours                   Float    @default(4)
  monthlyLeaveEntitlement        Float    @default(1)
  pfRate                         Float    @default(12)
  esiRate                        Float    @default(0.75)
  professionalTaxRate            Float    @default(200)
  tdsRate                        Float    @default(10)
  leaveEncashmentRate            Float    @default(30)
  footerText                     String?  
  customLeaveTypes               String?  
  salarySlipShowWatermark        Boolean  @default(false)
  salarySlipWatermarkText        String?
  salarySlipHeaderText           String?  
  salarySlipFooterText           String?  
  salarySlipSignatoryName        String?
  salarySlipSignatoryDesig       String?
  salarySlipShowLogo             Boolean  @default(true)
  salarySlipPrimaryColor         String   @default("#8B5CF6") 
  salarySlipShowDualSignatures   Boolean  @default(false)
  salarySlipSecondSignatory      String?
  salarySlipSecondSignatoryDesig String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  @@map("company_settings")
}

model Department {
  id          String     @id @default(cuid()) 
  name        String     @unique
  code        String     @unique
  description String?    
  managerId   String?    
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
  tasks       Task[]

  @@map("departments")
}

model EmployeeDocument {
  id            String    @id @default(cuid()) 
  employeeId    String    
  title         String
  documentType  String    
  fileUrl       String    
  fileName      String
  fileSize      Int
  status        String    @default("PENDING") 
  isLocked      Boolean   @default(false)
  uploadedAt    DateTime  @default(now())
  verifiedAt    DateTime?
  verifiedBy    String?   
  rejectionNote String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id])

  @@index([documentType])
  @@index([employeeId])
  @@map("employee_documents")
}

model Employee {
  id                        String                     @id @default(cuid()) 
  employeeCode              String                     @unique
  firstName                 String
  lastName                  String
  fatherName                String?
  email                     String                     @unique
  phone                     String?                    
  department                String
  departmentId              String?                    
  designation               String
  joiningDate               DateTime
  employmentType            String                     @default("FULL_TIME") 
  gender                    String?                    
  dateOfBirth               DateTime?
  address                   String?                    
  city                      String?
  state                     String?
  pincode                   String?                    
  panNumber                 String?                    
  aadhaarNumber             String?                    
  bankName                  String?
  accountNumber             String?                    
  ifscCode                  String?                    
  pfNumber                  String?                    
  uanNumber                 String?                    
  esiNumber                 String?                    
  emergencyContactName      String?
  emergencyContactPhone     String?                    
  maritalStatus             String?                    
  status                    String                     @default("ACTIVE") 
  profileImage              String?                    
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  profileCompleted          Boolean                    @default(false)
  deletedAt                 DateTime?
  attendance                Attendance[]
  attendanceRegularizations AttendanceRegularization[]
  auditLogs                 AuditLog[]
  documents                 EmployeeDocument[]
  departmentRef             Department?                @relation(fields: [departmentId], references: [id])
  hrLetters                 HRLetter[]
  leaveBalances             LeaveBalance[]
  leaveRequests             LeaveRequest[]
  notifications             Notification[]
  payrollItems              PayrollItem[]
  reimbursements            Reimbursement[]
  resignations              Resignation[]
  salaryStructures          SalaryStructure[]
  tasks                     Task[]
  tickets                   Ticket[]
  learningRequests          LearningRequest[]
  toolRequests              ToolRequest[]
  user                      User?

  @@index([departmentId])
  @@index([department])
  @@index([status])
  @@map("employees")
}

model EsslSetting {
  id                String    @id @default(cuid()) 
  portalUrl         String?   
  apiKey            String?   
  deviceIp          String?   
  departmentMapping String?   
  autoSyncEnabled   Boolean   @default(false)
  syncInterval      Int       @default(15)
  lastSyncAt        DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("essl_settings")
}

model EsslSyncLog {
  id               String    @id @default(cuid()) 
  syncType         String    
  status           String    
  recordsProcessed Int?
  recordsCreated   Int?
  recordsUpdated   Int?
  errors           String?   
  startedAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@map("essl_sync_logs")
}

model Holiday {
  id          String   @id @default(cuid()) 
  name        String
  date        DateTime
  year        Int
  type        String   @default("PUBLIC") 
  description String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, year])
  @@map("holidays")
}

model HRLetter {
  id         String    @id @default(cuid()) 
  employeeId String    
  type       String    
  title      String
  content    String?   
  status     String    @default("DRAFT") 
  issuedAt   DateTime?
  responseAt DateTime?
  createdBy  String    
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("hr_letters")
}

model LearningModule {
  id                 String   @id @default(cuid()) 
  title              String
  description        String?  
  category           String   
  fileUrl            String?  
  fileName           String?
  fileSize           Int?
  fileType           String?  
  thumbnailUrl       String?  
  duration           String?  
  isActive           Boolean  @default(true)
  isFeatured         Boolean  @default(false)
  views              Int      @default(0)
  enrollmentRequests String?  
  createdBy          String   
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("learning_modules")
}

model LearningProgress {
  id             String    @id @default(cuid()) 
  employeeId     String    
  moduleId       String    
  progress       Int       @default(0)
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  lastAccessedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([employeeId, moduleId])
  @@map("learning_progress")
}

model LeaveBalance {
  id              String   @id @default(cuid()) 
  employeeId      String   
  leaveType       String   
  year            Int
  entitled        Float    @default(0)
  taken           Float    @default(0)
  pending         Float    @default(0)
  available       Float    @default(0)
  carryForward    Float    @default(0)
  carryForwardMax Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveType, year])
  @@index([employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id         String    @id @default(cuid()) 
  employeeId String    
  leaveType  String    
  startDate  DateTime
  endDate    DateTime
  totalDays  Float
  halfDay    Boolean   @default(false)
  reason     String?   
  status     String    @default("PENDING") 
  appliedAt  DateTime  @default(now())
  approvedBy String?   
  approvedAt DateTime?
  remarks    String?   
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([appliedAt])
  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

model LoginSession {
  id         String    @id @default(cuid()) 
  userId     String    
  ipAddress  String?   
  city       String?   
  country    String?   
  deviceType String?   
  browser    String?   
  os         String?   
  userAgent  String?   
  sessionId  String?   @unique
  loginAt    DateTime  @default(now())
  logoutAt   DateTime?
  isActive   Boolean   @default(true)
  user       User      @relation(fields: [userId], references: [id])

  @@index([isActive])
  @@index([loginAt])
  @@index([userId])
  @@map("login_sessions")
}

model Notification {
  id         String    @id @default(cuid()) 
  employeeId String?   
  title      String
  message    String    
  type       String    @default("SYSTEM") 
  isRead     Boolean   @default(false)
  readAt     DateTime?
  link       String?   
  createdAt  DateTime  @default(now())
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([isRead])
  @@map("notifications")
}

model PayrollItem {
  id                   String    @id @default(cuid()) 
  employeeId           String    
  month                Int
  year                 Int
  basicSalary          Float
  hra                  Float
  conveyanceAllowance  Float
  medicalAllowance     Float
  specialAllowance     Float
  otherAllowance       Float
  bonus                Float     @default(0)
  incentives           Float     @default(0)
  grossSalary          Float
  pfDeduction          Float
  esiDeduction         Float
  professionalTax      Float
  tdsDeduction         Float     @default(0)
  otherDeduction       Float
  unpaidLeaveDeduction Float     @default(0)
  totalDeduction       Float
  netSalary            Float
  paidDays             Float
  status               String    @default("DRAFT") 
  paidAt               DateTime?
  lockedAt             DateTime?
  lockedBy             String?   
  overrides            String?   
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  employee             Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
  @@map("payroll_items")
}

model Reimbursement {
  id          String    @id @default(cuid()) 
  employeeId  String    
  title       String
  description String?   
  amount      Float
  category    String    
  status      String    @default("PENDING") 
  receiptUrl  String?   
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?   
  notes       String?   
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("reimbursements")
}

model Resignation {
  id              String    @id @default(cuid()) 
  employeeId      String    
  reason          String?   
  intendedLastDay DateTime
  status          String    @default("PENDING") 
  reviewedAt      DateTime?
  reviewedBy      String?   
  reviewNotes     String?   
  actualLastDay   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("resignations")
}

model SalaryStructure {
  id                  String    @id @default(cuid()) 
  employeeId          String    
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  basicSalary         Float
  hra                 Float     @default(0)
  conveyanceAllowance Float     @default(0)
  medicalAllowance    Float     @default(0)
  specialAllowance    Float     @default(0)
  otherAllowance      Float     @default(0)
  pfDeduction         Float     @default(0)
  esiDeduction        Float     @default(0)
  professionalTax     Float     @default(0)
  otherDeduction      Float     @default(0)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  employee            Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("salary_structures")
}

model SmtpSetting {
  id        String   @id @default(cuid()) 
  host      String   @default("smtp.gmail.com")
  port      Int      @default(587)
  secure    Boolean  @default(false)
  username  String
  password  String   
  fromEmail String
  fromName  String   @default("Realvibe HRM")
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("smtp_settings")
}

model Task {
  id           String      @id @default(cuid()) 
  title        String
  description  String?     
  assignedTo   String      
  assignedBy   String?     
  departmentId String?     
  priority     String      @default("MEDIUM") 
  status       String      @default("PENDING") 
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  assignee     Employee    @relation(fields: [assignedTo], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([assignedTo])
  @@index([departmentId])
  @@index([status])
  @@map("tasks")
}

model Ticket {
  id          String    @id @default(cuid()) 
  employeeId  String    
  title       String
  description String    
  category    String    @default("GENERAL") 
  priority    String    @default("MEDIUM") 
  status      String    @default("OPEN") 
  assignedTo  String?   
  resolution  String?   
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("tickets")
}

model LearningRequest {
  id                String    @id @default(cuid()) 
  employeeId        String    
  courseName        String
  reason            String?   
  projectRelevance  String?   
  skillCategory     String?   
  priority          String    @default("MEDIUM") 
  courseLink         String?   
  expectedBenefit   String?   
  status            String    @default("PENDING") 
  reviewedBy        String?   
  reviewedAt        DateTime?
  reviewNotes       String?   
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  employee          Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("learning_requests")
}

model ToolRequest {
  id              String    @id @default(cuid()) 
  employeeId      String    
  toolName        String
  reason          String    
  projectName     String?
  priority        String    @default("MEDIUM") 
  requiredByDate  DateTime?
  remarks         String?   
  status          String    @default("PENDING") 
  assignedToolId  String?   
  reviewedBy      String?   
  reviewedAt      DateTime?
  reviewNotes     String?   
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employee        Employee  @relation(fields: [employeeId], references: [id])
  assignedTool    Tool?     @relation(fields: [assignedToolId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("tool_requests")
}

model Tool {
  id                String   @id @default(cuid()) 
  name              String
  description       String?  
  type              String   @default("OTHER") 
  url               String?  
  username          String?
  password          String?  
  encryptedPassword String?  
  notes             String?  
  category          String?  
  isShared          Boolean  @default(false)
  accessRequests    String?  
  createdBy         String   
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  toolRequests      ToolRequest[]

  @@map("tools")
}

model User {
  id            String         @id @default(cuid()) 
  email         String         @unique
  password      String
  role          String         @default("EMPLOYEE") 
  employeeId    String?        @unique 
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  loginSessions LoginSession[]
  employee      Employee?      @relation(fields: [employeeId], references: [id])

  @@map("users")
}
